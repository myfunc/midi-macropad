plugins/voice_scribe/chats/

# Beads (internal task tracker)
.beads/
AGENTS.md

# Research notes
RESEARCH-*.md

# Local screenshots (canonical copy is docs/screenshot.png)
/image.png

# Backups (local safety copies of configs/secrets)
backups/

# Sample packs (can be large, user-supplied)
plugins/sample_player/packs/*/samples/

# Piano instrument samples (generated by instruments/generate_builtin.py)
instruments/*/samples/

# Local-only: OBS scene snapshots (kept on disk, not in repo)
obs_backup/

# Local-only: research notes directory
researches/
